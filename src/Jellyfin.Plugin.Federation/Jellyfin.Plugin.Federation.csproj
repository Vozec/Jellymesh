<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <RootNamespace>Jellyfin.Plugin.Federation</RootNamespace>
    <AssemblyName>Jellyfin.Plugin.Federation</AssemblyName>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <TreatWarningsAsErrors>false</TreatWarningsAsErrors>
    <GenerateAssemblyInfo>true</GenerateAssemblyInfo>
    <Version>0.9.1.0</Version>
    <FileVersion>0.9.1.0</FileVersion>
    <AssemblyVersion>0.9.1.0</AssemblyVersion>
  </PropertyGroup>

  <PropertyGroup>
    <!-- Override at build time: `dotnet build /p:JellyfinAbi=10.9.11` builds a 10.9-compatible
         variant that pins Controller+Model + Sqlite to the matching set. -->
    <JellyfinAbi Condition="'$(JellyfinAbi)'==''">10.10.3</JellyfinAbi>
    <SqliteVersion Condition="'$(SqliteVersion)'=='' AND $(JellyfinAbi.StartsWith('10.9'))">7.0.20</SqliteVersion>
    <SqliteVersion Condition="'$(SqliteVersion)'==''">8.0.10</SqliteVersion>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Jellyfin.Controller" Version="$(JellyfinAbi)" />
    <PackageReference Include="Jellyfin.Model" Version="$(JellyfinAbi)" />
    <PackageReference Include="Microsoft.Data.Sqlite" Version="$(SqliteVersion)" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="Configuration\configPage.html" />
    <EmbeddedResource Include="Assets\thumb.png" />
    <EmbeddedResource Include="Assets\logo.svg" />
    <EmbeddedResource Include="Assets\jellymesh-item.js" />
    <EmbeddedResource Include="Assets\i18n\*.json" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Jellyfin.Plugin.Federation.Tests" />
  </ItemGroup>

</Project>
